---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getPosts } from '../lib/posts';

const posts = await getPosts();
const recent = posts.slice(0, 3);
const more = posts.slice(3, 6);
---

<BaseLayout title="UnglamorousAI">
  <main>
    <section class="container hero">
      <div class="hero-comment"><span>// </span>a working notebook for the AI that isn't on the keynote stage</div>
      <h1>I talk about the <span>boring AI work</span> between the <span>hype</span> and the <span>deploy</span>.</h1>
      <p>Long-form tutorials, sharp notes, and streams from a practitioner. <br />Just the unglamorous parts that solve the problem.</p>
      <div class="hero-cta"><a class="btn btn-primary" href="/writing/">read the writing →</a><a class="btn btn-ghost" href="/about/">who is writing this?</a><a class="btn btn-ghost" href="/about-the-artist/">who's the artist?</a></div>
    </section>
    <section class="container">
      <SectionHeader prompt="ls -lt ./writing | head -3" hint="three most recent" actionHref="/writing/" actionLabel="see all →" />
      <div class="cards3">{recent.map((post) => <PostCard post={post} />)}</div>
    </section>
    <section class="container home-split">
      <div><SectionHeader prompt="tail ./writing" hint="also recent" />{more.map((post) => <PostCard post={post} variant="row" />)}</div>
      <aside class="commit-feed"><SectionHeader prompt="git log --all" hint="from the repos" /><div class="empty">mock commit feed until github handle is confirmed</div></aside>
    </section>
    <!--
    <section class="container newsletter" id="newsletter"><div class="pattern">// subscribe()
// returns: one email, every other tuesday,
// no growth-hacked subject lines,
// no "you won't believe what GPT did next".
// unsubscribe is one click and i won't be weird about it.
// subscribe()
// returns: one email, every other tuesday,
// no growth-hacked subject lines,
// no "you won't believe what GPT did next".
// unsubscribe is one click and i won't be weird about it.
      </div><div class="content"><div><div class="label">$ subscribe --no-bullshit</div><h3>One email, every other Tuesday. The agents I shipped, the ones I scrapped.</h3></div><form><input type="email" placeholder="you@yourcompany.com" /><button class="btn btn-primary" type="button">subscribe</button></form></div></section> -->
  </main>
</BaseLayout>
