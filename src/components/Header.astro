---
import Clock from '../islands/Clock';

const route = Astro.url.pathname;
const nav = [
  { label: 'writing', href: '/writing/' },
  { label: 'streams', href: '/streams/' },
  { label: 'about', href: '/about/' },
  { label: 'glossary', href: '/writing/glossary' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark">
      <span class="muted">~/</span>U<span class="muted">nglamorous</span>AI<span class="blink">▊</span>
    </a>
    <nav>
      {nav.map((item) => (
        <a href={item.href} class={route.startsWith(item.href.replace(/\/$/, '')) ? 'active' : ''}>{item.label}</a>
      ))}
      <Clock client:idle />
    </nav>
  </div>
</header>
